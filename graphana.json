            },
            {
              "options": {
                "from": 70,
                "result": {
                  "text": "GOOD"
                },
                "to": 84
              },
              "type": "range"
            },
            {
              "options": {
                "from": 50,
                "result": {
                  "text": "MODERATE"
                },
                "to": 69
              },
              "type": "range"
            },
            {
              "options": {
                "from": 0,
                "result": {
                  "text": "POOR"
                },
                "to": 49
              },
              "type": "range"
            }
          ],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "green",
                "value": 85
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "rawQueryText": "SELECT ROUND(MAX(0, MIN(100, 100 - MAX(0, (co2 - 400) / 16.0) - MAX(0, tvoc / 10.0) - MAX(0, ABS(humidity - 45) / 2.0) - MAX(0, (temperature - 22) * 2))), 0) AS score FROM readings ORDER BY ts DESC LIMIT 1",
          "refId": "A",
          "timeColumns": []
        }
      ],
      "title": "AIR QUALITY SCORE",
      "type": "stat"
    },
