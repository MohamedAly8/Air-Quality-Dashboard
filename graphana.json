      "description": "0–100 composite score combining CO₂, TVOC, humidity and temperature",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "from": 85,
                "result": {
                  "text": "EXCELLENT"
                },
